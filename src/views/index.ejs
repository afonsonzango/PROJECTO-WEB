<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>EduMatric | Excelência em Gestão Escolar</title>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <script src="https://cdn.jsdelivr.net/npm/particles.js@2.0.0/particles.min.js"></script>
  <style>
    body { background: var(--bg-dark); }

    #particles-js {
      position: fixed;
      inset: 0;
      z-index: -1;
    }

    .bg-mesh {
      position: fixed;
      inset: 0;
      background-image:
        radial-gradient(at 0% 0%,   rgba(0,82,204,0.3)   0px, transparent 50%),
        radial-gradient(at 100% 100%, rgba(0,212,255,0.15) 0px, transparent 50%);
      z-index: -2;
    }

    /* ---- Header ---- */
    .site-header {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      z-index: 50;
      padding: 16px 24px;
    }
    .header-inner {
      max-width: 1280px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 16px 32px;
      border-radius: 16px;
    }
    .logo { display: flex; align-items: center; gap: 16px; }
    .logo-icon {
      width: 40px; height: 40px;
      background: white;
      border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
    }
    .logo-icon span { color: #1d4ed8; font-weight: 900; font-size: 0.8rem; }
    .logo-text h1 { font-size: 1.2rem; font-weight: 800; letter-spacing: -0.02em; line-height: 1; }
    .logo-text small { font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.2em; color: #93c5fd; font-weight: 700; }
    .menu-btn {
      background: none; border: none; color: white; cursor: pointer;
      padding: 8px; border-radius: 8px;
      transition: background 0.2s;
    }
    .menu-btn:hover { background: rgba(255,255,255,0.1); }
    .menu-btn svg { display: block; }

    /* ---- Side menu ---- */
    #overlay {
      position: fixed; inset: 0;
      background: rgba(3,16,56,0.8);
      backdrop-filter: blur(6px);
      z-index: 40;
      display: none;
    }
    #sideMenu {
      position: fixed; top: 0; right: 0;
      width: 320px; height: 100%;
      background: rgba(255,255,255,0.98);
      color: #001a40;
      z-index: 50;
      padding: 40px;
      transform: translateX(100%);
      transition: transform 0.4s cubic-bezier(0.8,0,0.2,1);
      overflow-y: auto;
    }
    .menu-close-btn {
      background: none; border: none; cursor: pointer;
      padding: 8px; border-radius: 50%;
      margin-bottom: 48px; display: block;
      transition: background 0.2s;
    }
    .menu-close-btn:hover { background: #eff6ff; }
    .menu-section-label {
      font-size: 0.7rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.2em;
      color: #60a5fa; margin-bottom: 16px;
    }
    .menu-links { display: flex; flex-direction: column; gap: 10px; }
    .menu-link-main {
      font-size: 1.05rem; font-weight: 700;
      color: #1e3a8a;
      display: flex; align-items: center;
      background: white; padding: 8px 16px;
      border-radius: 8px; transition: color 0.2s;
    }
    .menu-link-main:hover { color: #2563eb; }
    .menu-divider { border: none; border-top: 1px solid #dbeafe; margin: 24px 0; }
    .menu-link-sec {
      font-weight: 600; color: #475569;
      padding: 6px 16px; border-radius: 8px;
      display: block; transition: color 0.2s;
    }
    .menu-link-sec:hover { color: #2563eb; }

    /* ---- Hero ---- */
    .hero {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 128px 24px 0;
      text-align: center;
    }
    .badge {
      display: inline-block;
      background: rgba(59,130,246,0.2);
      border: 1px solid rgba(59,130,246,0.3);
      padding: 8px 24px;
      border-radius: 9999px;
      font-size: 0.7rem; font-weight: 900;
      text-transform: uppercase; letter-spacing: 0.3em;
      color: #93c5fd; margin-bottom: 32px;
    }
    .hero-title {
      font-size: clamp(3rem, 10vw, 6rem);
      font-weight: 900; letter-spacing: -0.04em;
      line-height: 1; margin-bottom: 32px;
      background: linear-gradient(180deg, #fff 0%, #bfdbfe 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    #typing::after { content: '|'; animation: blink 1s infinite; color: var(--secondary); }
    @keyframes blink { 50% { opacity: 0; } }
    .hero-sub {
      font-size: clamp(1rem, 2.5vw, 1.3rem); font-weight: 300;
      color: rgba(191,219,254,0.8); max-width: 640px;
      line-height: 1.7; margin-bottom: 48px;
    }
    .hero-sub strong { font-weight: 700; color: white; }
    .cta-group {
      display: flex; flex-wrap: wrap; justify-content: center;
      gap: 24px; margin-bottom: 96px;
    }

    /* ---- Cards ---- */
    .cards-section {
      width: 100%; max-width: 1280px; padding: 0 16px;
    }
    .cards-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 32px;
    }
    @media (max-width: 900px) { .cards-grid { grid-template-columns: 1fr; } }
    .card {
      padding: 40px; border-radius: 40px;
      position: relative; overflow: hidden;
    }
    .card-icon {
      width: 56px; height: 56px;
      border-radius: 16px;
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 32px;
    }
    .card-icon svg { width: 32px; height: 32px; color: white; }
    .card h4 { font-size: 1.4rem; font-weight: 900; margin-bottom: 24px; }
    .course-list { list-style: none; display: flex; flex-direction: column; gap: 16px; }
    .course-list li {
      display: flex; align-items: center; gap: 12px;
      color: rgba(191,219,254,0.7); font-weight: 500;
    }
    .dot { width: 8px; height: 8px; background: #60a5fa; border-radius: 50%; flex-shrink: 0; }
    .price-row {
      display: flex; justify-content: space-between; align-items: center;
      padding: 12px; border-radius: 12px;
      background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.05);
      margin-bottom: 12px;
    }
    .price-row:last-child { margin-bottom: 0; }
    .price-label { font-size: 0.9rem; opacity: 0.6; }
    .price-value { font-weight: 900; color: #93c5fd; }
    .fee-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
    .fee-row:last-child { margin-bottom: 0; }
    .fee-name { font-weight: 700; }
    .fee-sub { font-size: 0.6rem; text-transform: uppercase; opacity: 0.5; margin-top: 2px; }
    .fee-amount { font-size: 1.2rem; font-weight: 900; }

    /* ---- Footer ---- */
    .site-footer {
      margin-top: 128px;
      padding: 48px 24px;
      border-top: 1px solid rgba(255,255,255,0.1);
      background: rgba(3,16,56,0.5);
      backdrop-filter: blur(20px);
    }
    .footer-inner {
      max-width: 1280px; margin: 0 auto;
      display: flex; flex-wrap: wrap;
      justify-content: space-between; align-items: center; gap: 24px;
    }
    .footer-logo { display: flex; align-items: center; gap: 12px; }
    .footer-logo-icon {
      width: 32px; height: 32px; background: white;
      border-radius: 8px; display: flex; align-items: center; justify-content: center;
    }
    .footer-logo-icon span { color: #1e3a8a; font-weight: 900; font-size: 0.7rem; }
    .footer-brand { font-weight: 700; letter-spacing: -0.02em; }
    .footer-copy { font-size: 0.85rem; color: rgba(191,219,254,0.5); }
    .footer-links { display: flex; gap: 24px; }
    .footer-links a {
      font-size: 0.7rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.15em;
      color: #93c5fd; transition: color 0.2s;
    }
    .footer-links a:hover { color: white; }
  </style>
</head>
<body>
  <div class="bg-mesh"></div>
  <div id="particles-js"></div>

  <!-- Header -->
  <header class="site-header">
    <div class="header-inner glass">
      <div class="logo">
        <div class="logo-icon"><span>EM</span></div>
        <div class="logo-text">
          <h1>EduMatric</h1>
          <small>Portal Oficial</small>
        </div>
      </div>
      <button class="menu-btn" onclick="openMenu()" aria-label="Abrir menu">
        <svg width="28" height="28" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"/>
        </svg>
      </button>
    </div>
  </header>

  <!-- Overlay + Side Menu -->
  <div id="overlay" onclick="closeMenu()"></div>
  <nav id="sideMenu">
    <button class="menu-close-btn" onclick="closeMenu()" aria-label="Fechar menu">
      <svg width="28" height="28" fill="none" stroke="#001a40" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
    <p class="menu-section-label">Area de Login</p>
    <div class="menu-links">
      <a href="/login/aluno"      class="menu-link-main">Portal do Aluno</a>
      <a href="/login/secretaria" class="menu-link-main">Secretaria</a>
      <a href="/login/diretor"    class="menu-link-main">Diretor</a>
    </div>
    <hr class="menu-divider">
    <div class="menu-links">
      <a href="/status-matricula" class="menu-link-sec">Ver Status de Matricula</a>
      <a href="/fazer-matricula"  class="menu-link-sec">Fazer Matricula</a>
    </div>
  </nav>

  <!-- Hero -->
  <main class="hero">
    <div class="badge">
      <%= abertas ? 'Inscricoes Abertas' : 'Inscricoes Fechadas' %> &bull; Ano Lectivo 2025/2026
    </div>
    <h2 class="hero-title"><span id="typing"></span></h2>
    <p class="hero-sub">
      Modernize a sua jornada academica com o sistema de matriculas mais avancado do pais.
      <strong>Eficiencia, transparencia e inovacao.</strong>
    </p>
    <div class="cta-group">
      <a href="/fazer-matricula" class="btn-main">Fazer Matricula</a>
      <a href="/status-matricula" class="btn-outline">Ver Status</a>
    </div>

    <!-- Cards -->
    <div class="cards-section">
      <div class="cards-grid">

        <div class="card glass">
          <div class="card-icon" style="background:#2563eb;">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477
                   5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5
                   5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5
                   18c-1.746 0-3.332.477-4.5 1.253"/>
            </svg>
          </div>
          <h4>Cursos Tecnicos</h4>
          <ul class="course-list">
            <li><span class="dot"></span>Informatica de Gestao</li>
            <li><span class="dot"></span>Gestao Empresarial</li>
            <li><span class="dot"></span>Telecomunicacoes</li>
            <li><span class="dot"></span>Eletricidade Industrial</li>
          </ul>
        </div>

        <div class="card glass">
          <div class="card-icon" style="background:#0891b2;">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002
                   2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2
                   2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/>
            </svg>
          </div>
          <h4>Investimento</h4>
          <div class="price-row"><span class="price-label">10a Classe</span><span class="price-value">50.000 Kz</span></div>
          <div class="price-row"><span class="price-label">12a Classe</span><span class="price-value">60.000 Kz</span></div>
          <div class="price-row"><span class="price-label">13a Classe</span><span class="price-value">65.000 Kz</span></div>
        </div>

        <div class="card glass">
          <div class="card-icon" style="background:#4f46e5;">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2
                   2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0
                   012-2h2a2 2 0 012 2"/>
            </svg>
          </div>
          <h4>Taxas Adicionais</h4>
          <div class="fee-row">
            <div><p class="fee-name">Matricula</p><p class="fee-sub">Taxa de Inscricao</p></div>
            <span class="fee-amount">15.000 Kz</span>
          </div>
          <div class="fee-row">
            <div><p class="fee-name">Cartao e Uniforme</p><p class="fee-sub">Kit Escolar</p></div>
            <span class="fee-amount">7.000 Kz</span>
          </div>
        </div>

      </div>
    </div>
  </main>

  <!-- Footer -->
  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-logo">
        <div class="footer-logo-icon"><span>EM</span></div>
        <span class="footer-brand">EduMatric Online</span>
      </div>
      <p class="footer-copy">2026 Sistema Oficial de Matriculas. Todos os direitos reservados.</p>
      <div class="footer-links">
        <a href="#">Suporte</a>
        <a href="#">Privacidade</a>
      </div>
    </div>
  </footer>

  <script>
    function openMenu()  { document.getElementById('sideMenu').style.transform = 'translateX(0)';     document.getElementById('overlay').style.display = 'block'; }
    function closeMenu() { document.getElementById('sideMenu').style.transform = 'translateX(100%)';  document.getElementById('overlay').style.display = 'none';  }

    const text = "Bem-Vindo ao EduMatric";
    let i = 0;
    function typing() {
      if (i < text.length) {
        document.getElementById('typing').innerHTML += text.charAt(i++);
        setTimeout(typing, 70);
      }
    }
    window.onload = typing;

    particlesJS('particles-js', {
      particles: {
        number: { value: 80, density: { enable: true, value_area: 800 } },
        color: { value: '#ffffff' },
        shape: { type: 'circle' },
        opacity: { value: 0.3, random: true },
        size: { value: 3, random: true },
        line_linked: { enable: true, distance: 150, color: '#ffffff', opacity: 0.2, width: 1 },
        move: { enable: true, speed: 2, out_mode: 'out' }
      },
      interactivity: {
        detect_on: 'canvas',
        events: { onhover: { enable: true, mode: 'grab' }, onclick: { enable: true, mode: 'push' } },
        modes: { grab: { distance: 200, line_linked: { opacity: 0.5 } } }
      },
      retina_detect: true
    });
  </script>
</body>
</html>
