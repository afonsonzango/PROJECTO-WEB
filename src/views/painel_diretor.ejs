<!DOCTYPE html>
<html lang="pt">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Painel do Diretor | EduMatric</title>
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body class="bg-gray-900 text-gray-100">

<header class="bg-gradient-to-r from-gray-800 to-gray-900 border-b border-gray-700 sticky top-0 z-40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
            <div class="flex items-center gap-4">
                <a href="/" class="text-white hover:text-blue-400 transition text-lg">←</a>
                <div>
                    <h1 class="text-xl font-bold text-white">Painel do Diretor</h1>
                    <p class="text-gray-400 text-xs">Visão Geral do Sistema</p>
                </div>
            </div>
            <div class="flex items-center gap-2">
                <span class="text-sm text-gray-400">Olá, <strong class="text-white"><%= usuario %></strong></span>
                <a href="/logout/diretor" onclick="return confirm('Sair?')" class="bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded transition font-semibold">Sair</a>
            </div>
        </div>
    </div>
</header>

<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <% if (flash) { %>
    <div class="mb-6 p-4 <%= flash.tipo === 'sucesso' ? 'bg-green-900/50 border-green-700 text-green-100' : 'bg-red-900/50 border-red-700 text-red-100' %> border rounded-lg">
        <%= flash.msg %>
    </div>
    <% } %>

    <!-- STATUS MATRÍCULAS -->
    <div class="<%= abertas ? 'bg-gradient-to-r from-green-600 to-emerald-700' : 'bg-gradient-to-r from-red-600 to-red-700' %> rounded-lg p-6 shadow-lg mb-8 text-white">
        <div class="flex justify-between items-center flex-wrap gap-4">
            <div>
                <h3 class="text-lg font-black mb-1">Status das Matrículas</h3>
                <p class="text-sm opacity-90">Controle de inscrições do sistema</p>
            </div>
            <div class="text-right">
                <p class="text-3xl font-black"><%= abertas ? '🟢 ABERTAS' : '🔴 FECHADAS' %></p>
            </div>
        </div>
        <form method="POST" action="/diretor/toggle-matriculas" class="mt-4">
            <button type="submit" onclick="return confirm('Alterar status das matrículas?')"
                class="bg-white text-gray-900 font-black px-6 py-2 rounded hover:bg-gray-100 transition">
                <%= abertas ? '🔒 Fechar Matrículas' : '🔓 Abrir Matrículas' %>
            </button>
        </form>
    </div>

    <!-- STATS -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
        <div class="bg-gradient-to-br from-blue-600 to-blue-800 rounded-lg p-5 text-white shadow-lg">
            <p class="text-blue-100 text-xs font-semibold mb-1">TOTAL</p>
            <h2 class="text-4xl font-black"><%= stats.total %></h2>
        </div>
        <div class="bg-gradient-to-br from-yellow-500 to-orange-600 rounded-lg p-5 text-white shadow-lg">
            <p class="text-yellow-100 text-xs font-semibold mb-1">PENDENTES</p>
            <h2 class="text-4xl font-black"><%= stats.pendentes %></h2>
        </div>
        <div class="bg-gradient-to-br from-green-500 to-emerald-600 rounded-lg p-5 text-white shadow-lg">
            <p class="text-green-100 text-xs font-semibold mb-1">APROVADOS</p>
            <h2 class="text-4xl font-black"><%= stats.aprovados %></h2>
        </div>
        <div class="bg-gradient-to-br from-red-500 to-red-700 rounded-lg p-5 text-white shadow-lg">
            <p class="text-red-100 text-xs font-semibold mb-1">RECUSADOS</p>
            <h2 class="text-4xl font-black"><%= stats.recusados %></h2>
        </div>
    </div>

    <!-- GRÁFICOS -->
    <div class="grid md:grid-cols-2 gap-8 mb-8">
        <div class="bg-gray-800 rounded-lg p-6 border border-gray-700">
            <h3 class="text-lg font-bold text-white mb-4">Distribuição por Estado</h3>
            <div style="height:250px"><canvas id="graficoPizza"></canvas></div>
        </div>
        <div class="bg-gray-800 rounded-lg p-6 border border-gray-700">
            <h3 class="text-lg font-bold text-white mb-4">Resumo Numérico</h3>
            <div style="height:250px"><canvas id="graficoBarras"></canvas></div>
        </div>
    </div>

    <!-- MÉTRICAS -->
    <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-gray-800 rounded-lg p-6 border border-gray-700">
            <p class="text-gray-400 text-sm mb-2">Taxa de Aprovação</p>
            <p class="text-4xl font-black text-green-400">
                <%= stats.total > 0 ? Math.round((stats.aprovados / stats.total) * 100) : 0 %>%
            </p>
        </div>
        <div class="bg-gray-800 rounded-lg p-6 border border-gray-700">
            <p class="text-gray-400 text-sm mb-2">Taxa de Recusa</p>
            <p class="text-4xl font-black text-red-400">
                <%= stats.total > 0 ? Math.round((stats.recusados / stats.total) * 100) : 0 %>%
            </p>
        </div>
        <div class="bg-gray-800 rounded-lg p-6 border border-gray-700">
            <p class="text-gray-400 text-sm mb-2">Reconfirmações Pendentes</p>
            <p class="text-4xl font-black text-purple-400"><%= stats.reconfirmacoes %></p>
        </div>
    </div>

</main>

<script>
new Chart(document.getElementById('graficoPizza').getContext('2d'),{
    type:'doughnut',
    data:{labels:['Pendentes','Aprovados','Recusados'],datasets:[{backgroundColor:['#f59e0b','#10b981','#ef4444'],data:[<%= stats.pendentes %>,<%= stats.aprovados %>,<%= stats.recusados %>]}]},
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{labels:{color:'#d1d5db'}}}}
});
new Chart(document.getElementById('graficoBarras').getContext('2d'),{
    type:'bar',
    data:{labels:['Pendentes','Aprovados','Recusados'],datasets:[{label:'Alunos',backgroundColor:['#f59e0b','#10b981','#ef4444'],data:[<%= stats.pendentes %>,<%= stats.aprovados %>,<%= stats.recusados %>]}]},
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{labels:{color:'#d1d5db'}}},scales:{y:{ticks:{color:'#9ca3af'},grid:{color:'#374151'}},x:{ticks:{color:'#9ca3af'},grid:{color:'#374151'}}}}
});
</script>
</body>
</html>
