<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Painel do Diretor | EduMatric</title>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    body { background: #0f172a; font-family: var(--font); min-height: 100vh; }

    .topbar { background: #1e293b; border-bottom: 1px solid #334155; position: sticky; top: 0; z-index: 40; }
    .topbar-inner { max-width: 1280px; margin: 0 auto; padding: 0 24px; display: flex; justify-content: space-between; align-items: center; height: 64px; }
    .topbar-left { display: flex; align-items: center; gap: 16px; }
    .topbar-back { color: #94a3b8; font-size: 1.2rem; transition: color 0.2s; }
    .topbar-back:hover { color: white; }
    .topbar-title { font-size: 1.1rem; font-weight: 700; color: white; }
    .topbar-subtitle { font-size: 0.75rem; color: #64748b; }
    .topbar-right { display: flex; align-items: center; gap: 8px; }
    .topbar-user { font-size: 0.85rem; color: #94a3b8; }
    .topbar-user strong { color: white; }
    .btn-icon { padding: 8px 16px; border: none; border-radius: 6px; cursor: pointer; font-family: var(--font); font-size: 0.85rem; font-weight: 600; transition: background 0.2s; }
    .btn-red { background: #dc2626; color: white; }
    .btn-red:hover { background: #b91c1c; }

    .main { max-width: 1280px; margin: 0 auto; padding: 32px 24px; }

    .flash { padding: 12px 16px; border-radius: 8px; font-size: 0.9rem; margin-bottom: 24px; }
    .flash-ok  { background: rgba(34,197,94,0.1);  border: 1px solid rgba(34,197,94,0.3);  color: #86efac; }
    .flash-err { background: rgba(239,68,68,0.1);  border: 1px solid rgba(239,68,68,0.3);  color: #fca5a5; }

    /* Status banner */
    .status-banner { border-radius: 12px; padding: 24px 28px; margin-bottom: 32px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; }
    .status-banner.open   { background: linear-gradient(135deg, #15803d, #166534); }
    .status-banner.closed { background: linear-gradient(135deg, #b91c1c, #991b1b); }
    .status-info h3 { font-size: 1.1rem; font-weight: 900; color: white; margin-bottom: 4px; }
    .status-info p  { font-size: 0.85rem; color: rgba(255,255,255,0.7); }
    .status-right { display: flex; align-items: center; gap: 20px; flex-wrap: wrap; }
    .status-label { font-size: 1.5rem; font-weight: 900; color: white; }
    .btn-toggle { padding: 10px 24px; background: white; color: #111; font-weight: 700; font-size: 0.95rem; border: none; border-radius: 8px; cursor: pointer; font-family: var(--font); transition: opacity 0.2s; }
    .btn-toggle:hover { opacity: 0.9; }

    /* Stats */
    .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 32px; }
    @media (max-width: 700px) { .stats-grid { grid-template-columns: 1fr 1fr; } }
    .stat-card { border-radius: 12px; padding: 20px; color: white; }
    .stat-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; opacity: 0.8; }
    .stat-num { font-size: 2.5rem; font-weight: 900; margin-top: 8px; }
    .stat-blue   { background: linear-gradient(135deg, #2563eb, #1d4ed8); }
    .stat-yellow { background: linear-gradient(135deg, #d97706, #b45309); }
    .stat-green  { background: linear-gradient(135deg, #16a34a, #15803d); }
    .stat-red    { background: linear-gradient(135deg, #dc2626, #b91c1c); }

    /* Charts */
    .charts-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 32px; }
    @media (max-width: 700px) { .charts-grid { grid-template-columns: 1fr; } }
    .chart-card { background: #1e293b; border: 1px solid #334155; border-radius: 12px; padding: 24px; }
    .chart-card h3 { font-size: 0.95rem; font-weight: 700; color: white; margin-bottom: 16px; }
    .chart-wrap { height: 220px; }

    /* Metrics */
    .metrics-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
    @media (max-width: 600px) { .metrics-grid { grid-template-columns: 1fr; } }
    .metric-card { background: #1e293b; border: 1px solid #334155; border-radius: 12px; padding: 20px; }
    .metric-label { font-size: 0.8rem; color: #94a3b8; margin-bottom: 8px; }
    .metric-value { font-size: 2.2rem; font-weight: 900; }
    .text-green  { color: #4ade80; }
    .text-red    { color: #f87171; }
    .text-purple { color: #c084fc; }
  </style>
</head>
<body>

  <header class="topbar">
    <div class="topbar-inner">
      <div class="topbar-left">
        <a href="/" class="topbar-back">&#8592;</a>
        <div>
          <p class="topbar-title">Painel do Diretor</p>
          <p class="topbar-subtitle">Visao Geral do Sistema</p>
        </div>
      </div>
      <div class="topbar-right">
        <span class="topbar-user">Ola, <strong><%= usuario %></strong></span>
        <a href="/logout/diretor" onclick="return confirm('Sair do sistema?')">
          <button class="btn-icon btn-red">Sair</button>
        </a>
      </div>
    </div>
  </header>

  <main class="main">

    <% if (flash) { %>
    <div class="flash <%= flash.tipo === 'sucesso' ? 'flash-ok' : 'flash-err' %>"><%= flash.msg %></div>
    <% } %>

    <!-- Status banner -->
    <div class="status-banner <%= abertas ? 'open' : 'closed' %>">
      <div class="status-info">
        <h3>Status das Matriculas</h3>
        <p>Controle de inscricoes do sistema</p>
      </div>
      <div class="status-right">
        <span class="status-label"><%= abertas ? 'Abertas' : 'Fechadas' %></span>
        <form method="POST" action="/diretor/toggle-matriculas">
          <button type="submit" class="btn-toggle" onclick="return confirm('Alterar status das matriculas?')">
            <%= abertas ? 'Fechar Matriculas' : 'Abrir Matriculas' %>
          </button>
        </form>
      </div>
    </div>

    <!-- Stats -->
    <div class="stats-grid">
      <div class="stat-card stat-blue">  <p class="stat-label">Total</p>     <p class="stat-num"><%= stats.total %></p></div>
      <div class="stat-card stat-yellow"><p class="stat-label">Pendentes</p> <p class="stat-num"><%= stats.pendentes %></p></div>
      <div class="stat-card stat-green"> <p class="stat-label">Aprovados</p> <p class="stat-num"><%= stats.aprovados %></p></div>
      <div class="stat-card stat-red">   <p class="stat-label">Recusados</p> <p class="stat-num"><%= stats.recusados %></p></div>
    </div>

    <!-- Charts -->
    <div class="charts-grid">
      <div class="chart-card">
        <h3>Distribuicao por Estado</h3>
        <div class="chart-wrap"><canvas id="graficoPizza"></canvas></div>
      </div>
      <div class="chart-card">
        <h3>Resumo Numerico</h3>
        <div class="chart-wrap"><canvas id="graficoBarras"></canvas></div>
      </div>
    </div>

    <!-- Metrics -->
    <div class="metrics-grid">
      <div class="metric-card">
        <p class="metric-label">Taxa de Aprovacao</p>
        <p class="metric-value text-green"><%= stats.total > 0 ? Math.round((stats.aprovados / stats.total) * 100) : 0 %>%</p>
      </div>
      <div class="metric-card">
        <p class="metric-label">Taxa de Recusa</p>
        <p class="metric-value text-red"><%= stats.total > 0 ? Math.round((stats.recusados / stats.total) * 100) : 0 %>%</p>
      </div>
      <div class="metric-card">
        <p class="metric-label">Reconfirmacoes Pendentes</p>
        <p class="metric-value text-purple"><%= stats.reconfirmacoes %></p>
      </div>
    </div>

  </main>

  <script>
    new Chart(document.getElementById('graficoPizza').getContext('2d'), {
      type: 'doughnut',
      data: {
        labels: ['Pendentes','Aprovados','Recusados'],
        datasets: [{ backgroundColor: ['#d97706','#16a34a','#dc2626'], data: [<%= stats.pendentes %>,<%= stats.aprovados %>,<%= stats.recusados %>] }]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { labels: { color: '#94a3b8' } } }
      }
    });
    new Chart(document.getElementById('graficoBarras').getContext('2d'), {
      type: 'bar',
      data: {
        labels: ['Pendentes','Aprovados','Recusados'],
        datasets: [{ label: 'Alunos', backgroundColor: ['#d97706','#16a34a','#dc2626'], data: [<%= stats.pendentes %>,<%= stats.aprovados %>,<%= stats.recusados %>] }]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { labels: { color: '#94a3b8' } } },
        scales: {
          y: { ticks: { color: '#64748b' }, grid: { color: '#1e293b' } },
          x: { ticks: { color: '#64748b' }, grid: { color: '#1e293b' } }
        }
      }
    });
  </script>
</body>
</html>
