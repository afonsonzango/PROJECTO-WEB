<!DOCTYPE html>
<html lang="pt">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Painel da Secretária | EduMatric</title>
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body class="bg-gray-900 text-gray-100">

<header class="bg-gradient-to-r from-gray-800 to-gray-900 border-b border-gray-700 sticky top-0 z-40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
            <div class="flex items-center gap-4">
                <a href="/" class="text-white hover:text-blue-400 transition text-lg">←</a>
                <div>
                    <h1 class="text-xl font-bold text-white">Painel da Secretária</h1>
                    <p class="text-gray-400 text-xs">Gestão de Matrículas</p>
                </div>
            </div>
            <div class="flex items-center gap-2">
                <span class="text-sm text-gray-400">Olá, <strong class="text-white"><%= usuario %></strong></span>
                <button onclick="document.getElementById('senhaModal').classList.remove('hidden')" class="bg-yellow-600 hover:bg-yellow-700 text-white px-3 py-2 rounded text-sm font-semibold transition">🔑</button>
                <a href="/logout/secretaria" onclick="return confirm('Tem a certeza?')" class="bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded transition font-semibold">Sair</a>
            </div>
        </div>
    </div>
</header>

<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <!-- MODAL ALTERAR SENHA -->
    <div id="senhaModal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
        <div class="bg-gray-800 border border-gray-700 rounded-lg p-6 w-full max-w-sm">
            <h3 class="text-lg font-bold text-white mb-4">Alterar Senha</h3>
            <form method="POST" action="/secretaria/alterar-senha" class="space-y-3">
                <input type="password" name="senha_atual" placeholder="Senha atual" required class="w-full bg-gray-700 border border-gray-600 rounded px-3 py-2 text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-yellow-500">
                <input type="password" name="senha_nova" placeholder="Nova senha" required class="w-full bg-gray-700 border border-gray-600 rounded px-3 py-2 text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-yellow-500">
                <div class="flex gap-2">
                    <button type="submit" class="flex-1 bg-yellow-600 hover:bg-yellow-700 text-white px-4 py-2 rounded font-semibold transition">Atualizar</button>
                    <button type="button" onclick="document.getElementById('senhaModal').classList.add('hidden')" class="flex-1 bg-gray-600 hover:bg-gray-700 text-white px-4 py-2 rounded font-semibold transition">Cancelar</button>
                </div>
            </form>
        </div>
    </div>

    <!-- FLASH -->
    <% if (flash) { %>
    <div class="mb-6 p-4 <%= flash.tipo === 'sucesso' ? 'bg-green-900/50 border-green-700 text-green-100' : 'bg-red-900/50 border-red-700 text-red-100' %> border rounded-lg">
        <%= flash.msg %>
    </div>
    <% } %>

    <!-- STATS -->
    <div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-8">
        <div class="bg-gradient-to-br from-blue-600 to-blue-800 rounded-lg p-4 text-white shadow-lg">
            <p class="text-blue-100 text-xs font-semibold">TOTAL</p>
            <h2 class="text-3xl font-black mt-2"><%= stats.total %></h2>
        </div>
        <div class="bg-gradient-to-br from-yellow-500 to-orange-600 rounded-lg p-4 text-white shadow-lg">
            <p class="text-yellow-100 text-xs font-semibold">PENDENTES</p>
            <h2 class="text-3xl font-black mt-2"><%= stats.pendentes %></h2>
        </div>
        <div class="bg-gradient-to-br from-green-500 to-emerald-600 rounded-lg p-4 text-white shadow-lg">
            <p class="text-green-100 text-xs font-semibold">APROVADOS</p>
            <h2 class="text-3xl font-black mt-2"><%= stats.aprovados %></h2>
        </div>
        <div class="bg-gradient-to-br from-red-500 to-red-700 rounded-lg p-4 text-white shadow-lg">
            <p class="text-red-100 text-xs font-semibold">RECUSADOS</p>
            <h2 class="text-3xl font-black mt-2"><%= stats.recusados %></h2>
        </div>
        <div class="bg-gradient-to-br from-purple-500 to-indigo-600 rounded-lg p-4 text-white shadow-lg">
            <p class="text-purple-100 text-xs font-semibold">RECONF.</p>
            <h2 class="text-3xl font-black mt-2"><%= stats.reconfirmacoes %></h2>
        </div>
    </div>

    <!-- GRÁFICO -->
    <div class="bg-gray-800 rounded-lg p-6 shadow-lg border border-gray-700 mb-8">
        <h3 class="text-lg font-bold text-white mb-4">Distribuição de Matrículas</h3>
        <div style="height:250px"><canvas id="grafico"></canvas></div>
    </div>

    <!-- NAVEGAÇÃO -->
    <div class="flex gap-2 mb-6 flex-wrap">
        <button onclick="showSection('dashboard')" class="bg-blue-700 hover:bg-blue-600 text-white px-4 py-2 rounded font-semibold transition">📊 Dashboard</button>
        <button onclick="showSection('alunos')" class="bg-blue-700 hover:bg-blue-600 text-white px-4 py-2 rounded font-semibold transition">👥 Matrículas</button>
        <button onclick="showSection('reconfirmacoes')" class="bg-purple-700 hover:bg-purple-600 text-white px-4 py-2 rounded font-semibold transition">🔄 Reconfirmações</button>
    </div>

    <!-- DASHBOARD -->
    <section id="sec-dashboard" class="section bg-gray-800 rounded-lg p-6 shadow-lg border border-gray-700 mb-8">
        <h2 class="text-lg font-bold text-white mb-4">📊 Resumo Geral</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="bg-gray-700 rounded p-4">
                <p class="text-gray-300 mb-2">Taxa de Aprovação</p>
                <p class="text-3xl font-black text-blue-400">
                    <%= stats.total > 0 ? Math.round((stats.aprovados / stats.total) * 100) : 0 %>%
                </p>
            </div>
            <div class="bg-gray-700 rounded p-4">
                <p class="text-gray-300 mb-2">Total de Alunos</p>
                <p class="text-3xl font-black text-green-400"><%= stats.total %></p>
            </div>
        </div>
    </section>

    <!-- MATRÍCULAS -->
    <section id="sec-alunos" class="section hidden bg-gray-800 rounded-lg p-6 shadow-lg border border-gray-700 mb-8">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-6">
            <h2 class="text-lg font-bold text-white">Lista de Alunos</h2>
            <form method="GET" action="/secretaria/painel" class="flex gap-2">
                <input type="text" name="buscar" placeholder="Pesquisar por nome..." value="<%= busca %>"
                    class="border border-gray-600 rounded px-3 py-2 bg-gray-700 text-white placeholder-gray-400 flex-1">
                <button type="submit" class="bg-blue-700 hover:bg-blue-600 text-white px-4 py-2 rounded font-semibold">Pesquisar</button>
            </form>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead class="bg-gray-700 border-b border-gray-600">
                    <tr>
                        <th class="text-left py-3 px-3 text-gray-300">Nome</th>
                        <th class="text-left py-3 px-3 text-gray-300">Email</th>
                        <th class="text-left py-3 px-3 text-gray-300">Curso</th>
                        <th class="text-center py-3 px-3 text-gray-300">Estado</th>
                        <th class="text-left py-3 px-3 text-gray-300">Ações</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-700">
                <% alunos.forEach(a => { %>
                    <tr class="hover:bg-gray-700/50 transition">
                        <td class="py-3 px-3 text-gray-300"><%= a.nome %></td>
                        <td class="py-3 px-3 text-gray-400 text-xs"><%= a.email %></td>
                        <td class="py-3 px-3 text-gray-300"><%= a.curso %></td>
                        <td class="py-3 px-3 text-center">
                            <% if (a.estado === 'Pendente') { %>
                                <span class="bg-yellow-900/50 text-yellow-300 px-2 py-1 rounded text-xs font-bold">⏳</span>
                            <% } else if (a.estado === 'Aprovado') { %>
                                <span class="bg-green-900/50 text-green-300 px-2 py-1 rounded text-xs font-bold">✅</span>
                            <% } else { %>
                                <span class="bg-red-900/50 text-red-300 px-2 py-1 rounded text-xs font-bold">❌</span>
                            <% } %>
                        </td>
                        <td class="py-3 px-3">
                            <div class="flex gap-1">
                                <% if (a.estado === 'Pendente') { %>
                                <form method="POST" action="/secretaria/aprovar/<%= a.id %>">
                                    <button type="submit" onclick="return confirm('Aprovar matrícula de <%= a.nome %>?')" class="bg-green-700 hover:bg-green-600 text-white px-2 py-1 rounded text-xs font-semibold transition">✓</button>
                                </form>
                                <button onclick="openRecusar(<%= a.id %>, '<%= a.nome.replace(/'/g, `\\'`) %>')" class="bg-red-700 hover:bg-red-600 text-white px-2 py-1 rounded text-xs font-semibold transition">✗</button>
                                <% } %>
                                <button onclick='openDetalhes(<%- JSON.stringify(a) %>)' class="bg-gray-600 hover:bg-gray-500 text-white px-2 py-1 rounded text-xs font-semibold transition">👁</button>
                            </div>
                        </td>
                    </tr>
                <% }) %>
                <% if (alunos.length === 0) { %>
                    <tr><td colspan="5" class="text-center py-8 text-gray-400">Nenhum aluno encontrado</td></tr>
                <% } %>
                </tbody>
            </table>
        </div>
    </section>

    <!-- RECONFIRMAÇÕES -->
    <section id="sec-reconfirmacoes" class="section hidden bg-gray-800 rounded-lg p-6 shadow-lg border border-gray-700 mb-8">
        <h3 class="text-lg font-bold text-white mb-4">Reconfirmações Pendentes</h3>
        <div class="space-y-3">
        <% reconfirmacoes.forEach(r => { %>
            <div class="bg-gray-700 rounded-lg p-4 border border-purple-600/50">
                <div class="flex justify-between items-start flex-wrap gap-4">
                    <div>
                        <p class="font-bold text-white"><%= r.nome %></p>
                        <p class="text-sm text-gray-300"><%= r.email %></p>
                        <p class="text-xs text-gray-400">ID: <%= r.id_oficial %></p>
                    </div>
                    <div class="flex gap-2">
                        <form method="POST" action="/secretaria/aceitar-reconf/<%= r.id %>">
                            <button type="submit" class="bg-green-700 hover:bg-green-600 text-white px-3 py-1 rounded text-xs font-semibold">Aceitar</button>
                        </form>
                        <form method="POST" action="/secretaria/recusar-reconf/<%= r.id %>">
                            <button type="submit" class="bg-red-700 hover:bg-red-600 text-white px-3 py-1 rounded text-xs font-semibold">Recusar</button>
                        </form>
                    </div>
                </div>
            </div>
        <% }) %>
        <% if (reconfirmacoes.length === 0) { %>
            <p class="text-gray-400 text-center py-4">Nenhuma reconfirmação pendente</p>
        <% } %>
        </div>
    </section>

</main>

<!-- MODAL RECUSAR -->
<div id="modalRecusar" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-6">
    <div class="bg-gray-800 rounded-lg w-full max-w-lg p-6 border border-gray-700">
        <h3 class="text-lg font-bold text-white mb-4">Recusar Matrícula</h3>
        <form id="formRecusar" method="POST" class="space-y-4">
            <div>
                <label class="block text-sm text-gray-300 mb-2">Aluno</label>
                <input id="recusarNome" type="text" readonly class="w-full bg-gray-700 border border-gray-600 rounded px-3 py-2 text-gray-400">
            </div>
            <div>
                <label class="block text-sm text-gray-300 mb-2">Motivo</label>
                <textarea name="mensagem" required rows="4" class="w-full bg-gray-700 border border-gray-600 rounded px-3 py-2 text-white focus:outline-none focus:ring-2 focus:ring-red-500"></textarea>
            </div>
            <div class="flex justify-end gap-2">
                <button type="button" onclick="document.getElementById('modalRecusar').classList.add('hidden')" class="px-4 py-2 rounded border border-gray-600 text-gray-300 hover:bg-gray-700">Cancelar</button>
                <button type="submit" class="px-4 py-2 rounded bg-red-700 hover:bg-red-600 text-white font-semibold">Recusar</button>
            </div>
        </form>
    </div>
</div>

<!-- MODAL DETALHES -->
<div id="modalDetalhes" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-6">
    <div class="bg-gray-800 rounded-lg w-full max-w-2xl p-6 overflow-auto max-h-[80vh] border border-gray-700">
        <div class="flex justify-between items-center mb-4">
            <h3 class="text-lg font-bold text-white">Detalhes do Aluno</h3>
            <button onclick="document.getElementById('modalDetalhes').classList.add('hidden')" class="text-gray-400 hover:text-white text-xl">✕</button>
        </div>
        <div id="detalhesConteudo" class="space-y-3 text-sm"></div>
    </div>
</div>

<script>
const labels = {'Nome':'nome','Email':'email','Curso':'curso','Classe':'classe','Período':'periodo','Estado':'estado','ID Oficial':'id_oficial','NIF':'nif','Telefone':'telefone','Sexo':'sexo','Escola Anterior':'escola_anterior','Endereço':'endereco'};

function showSection(id){
    document.querySelectorAll('.section').forEach(s=>s.classList.add('hidden'));
    document.getElementById('sec-'+id).classList.remove('hidden');
}

function openRecusar(id, nome){
    document.getElementById('formRecusar').action = '/secretaria/recusar/'+id;
    document.getElementById('recusarNome').value = nome;
    document.getElementById('modalRecusar').classList.remove('hidden');
}

function openDetalhes(obj){
    const c = document.getElementById('detalhesConteudo');
    c.innerHTML = '';
    Object.entries(labels).forEach(([label, key]) => {
        const val = obj[key] ?? '—';
        c.innerHTML += `<div class="flex justify-between border-b border-gray-700 pb-2"><span class="text-gray-400 font-semibold">${label}</span><span class="text-gray-200 text-right">${val}</span></div>`;
    });
    document.getElementById('modalDetalhes').classList.remove('hidden');
}

// Fechar modals clicando fora
['modalRecusar','modalDetalhes'].forEach(id=>{
    document.getElementById(id).addEventListener('click',function(e){ if(e.target===this) this.classList.add('hidden'); });
});

// Gráfico
new Chart(document.getElementById('grafico').getContext('2d'),{
    type:'bar',
    data:{labels:['Pendentes','Aprovados','Recusados'],datasets:[{label:'Alunos',backgroundColor:['#f59e0b','#10b981','#ef4444'],data:[<%= stats.pendentes %>,<%= stats.aprovados %>,<%= stats.recusados %>]}]},
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{labels:{color:'#d1d5db'}}},scales:{y:{ticks:{color:'#9ca3af'},grid:{color:'#374151'}},x:{ticks:{color:'#9ca3af'},grid:{color:'#374151'}}}}
});

showSection('<%= secao %>');
</script>
</body>
</html>
