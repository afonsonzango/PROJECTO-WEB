<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Painel da Secretaria | EduMatric</title>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <style>
    body { background: #0f172a; font-family: var(--font); min-height: 100vh; }

    /* ---- Top bar ---- */
    .topbar {
      background: #1e293b; border-bottom: 1px solid #334155;
      position: sticky; top: 0; z-index: 40;
    }
    .topbar-inner {
      max-width: 1280px; margin: 0 auto; padding: 0 24px;
      display: flex; justify-content: space-between; align-items: center; height: 64px;
    }
    .topbar-left { display: flex; align-items: center; gap: 16px; }
    .topbar-back { color: #94a3b8; font-size: 1.2rem; transition: color 0.2s; }
    .topbar-back:hover { color: white; }
    .topbar-title { font-size: 1.1rem; font-weight: 700; color: white; }
    .topbar-subtitle { font-size: 0.75rem; color: #64748b; }
    .topbar-right { display: flex; align-items: center; gap: 8px; }
    .topbar-user { font-size: 0.85rem; color: #94a3b8; }
    .topbar-user strong { color: white; }
    .btn-icon { padding: 8px 12px; border: none; border-radius: 6px; cursor: pointer; font-family: var(--font); font-size: 0.8rem; font-weight: 600; transition: background 0.2s; }
    .btn-yellow { background: #d97706; color: white; }
    .btn-yellow:hover { background: #b45309; }
    .btn-red { background: #dc2626; color: white; }
    .btn-red:hover { background: #b91c1c; }

    /* ---- Layout ---- */
    .main { max-width: 1280px; margin: 0 auto; padding: 32px 24px; }

    /* ---- Flash ---- */
    .flash { padding: 12px 16px; border-radius: 8px; font-size: 0.9rem; margin-bottom: 24px; }
    .flash-ok  { background: rgba(34,197,94,0.1);  border: 1px solid rgba(34,197,94,0.3);  color: #86efac; }
    .flash-err { background: rgba(239,68,68,0.1);  border: 1px solid rgba(239,68,68,0.3);  color: #fca5a5; }

    /* ---- Stats grid ---- */
    .stats-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 16px; margin-bottom: 32px; }
    @media (max-width: 900px) { .stats-grid { grid-template-columns: repeat(2, 1fr); } }
    .stat-card { border-radius: 12px; padding: 18px; color: white; }
    .stat-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; opacity: 0.8; }
    .stat-num { font-size: 2.2rem; font-weight: 900; margin-top: 8px; }
    .stat-blue   { background: linear-gradient(135deg, #2563eb, #1d4ed8); }
    .stat-yellow { background: linear-gradient(135deg, #d97706, #b45309); }
    .stat-green  { background: linear-gradient(135deg, #16a34a, #15803d); }
    .stat-red    { background: linear-gradient(135deg, #dc2626, #b91c1c); }
    .stat-purple { background: linear-gradient(135deg, #7c3aed, #6d28d9); }

    /* ---- Nav tabs ---- */
    .nav-tabs { display: flex; gap: 8px; margin-bottom: 24px; flex-wrap: wrap; }
    .tab-btn { padding: 9px 20px; border: none; border-radius: 8px; cursor: pointer; font-family: var(--font); font-size: 0.85rem; font-weight: 600; transition: background 0.2s; }
    .tab-blue   { background: #1e40af; color: white; }
    .tab-blue:hover   { background: #1d4ed8; }
    .tab-purple { background: #6d28d9; color: white; }
    .tab-purple:hover { background: #7c3aed; }

    /* ---- Section card ---- */
    .section-card { background: #1e293b; border: 1px solid #334155; border-radius: 12px; padding: 24px; margin-bottom: 24px; }
    .section-card h2 { font-size: 1rem; font-weight: 700; color: white; margin-bottom: 20px; }

    /* ---- Summary boxes ---- */
    .summary-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    .summary-box { background: #0f172a; border-radius: 10px; padding: 18px; }
    .summary-box p:first-child { font-size: 0.85rem; color: #94a3b8; margin-bottom: 6px; }
    .summary-big { font-size: 2rem; font-weight: 900; }
    .text-blue { color: #60a5fa; } .text-green { color: #4ade80; }

    /* ---- Search row ---- */
    .search-row { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; margin-bottom: 20px; }
    .search-row input { flex: 1; min-width: 200px; padding: 9px 14px; background: #0f172a; border: 1px solid #334155; border-radius: 8px; color: white; font-family: var(--font); font-size: 0.9rem; outline: none; }
    .search-row input::placeholder { color: #475569; }
    .search-row input:focus { border-color: #3b82f6; }
    .btn-search { padding: 9px 18px; background: #1e40af; color: white; border: none; border-radius: 8px; cursor: pointer; font-family: var(--font); font-size: 0.85rem; font-weight: 600; transition: background 0.2s; }
    .btn-search:hover { background: #1d4ed8; }

    /* ---- Table ---- */
    .table-wrap { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
    thead { background: #0f172a; border-bottom: 1px solid #334155; }
    th { text-align: left; padding: 12px 14px; color: #94a3b8; font-weight: 600; font-size: 0.8rem; }
    tbody tr { border-bottom: 1px solid #1e293b; transition: background 0.15s; }
    tbody tr:hover { background: rgba(255,255,255,0.03); }
    td { padding: 12px 14px; color: #cbd5e1; }
    td.email { color: #64748b; font-size: 0.8rem; }

    .badge-row { display: inline-block; padding: 4px 10px; border-radius: 6px; font-size: 0.75rem; font-weight: 700; }
    .badge-pend { background: rgba(234,179,8,0.15); color: #fde68a; }
    .badge-aprov { background: rgba(34,197,94,0.15); color: #86efac; }
    .badge-recus { background: rgba(239,68,68,0.15); color: #fca5a5; }

    .action-btns { display: flex; gap: 6px; }
    .btn-approve { padding: 5px 10px; background: #166534; color: #86efac; border: none; border-radius: 6px; cursor: pointer; font-size: 0.8rem; font-weight: 600; font-family: var(--font); transition: background 0.2s; }
    .btn-approve:hover { background: #15803d; }
    .btn-reject-sm { padding: 5px 10px; background: #991b1b; color: #fca5a5; border: none; border-radius: 6px; cursor: pointer; font-size: 0.8rem; font-weight: 600; font-family: var(--font); transition: background 0.2s; }
    .btn-reject-sm:hover { background: #b91c1c; }
    .btn-view { padding: 5px 10px; background: #1e293b; border: 1px solid #334155; color: #94a3b8; border-radius: 6px; cursor: pointer; font-size: 0.8rem; font-family: var(--font); transition: background 0.2s; }
    .btn-view:hover { background: #334155; }

    /* ---- Reconf list ---- */
    .reconf-item { background: #0f172a; border: 1px solid rgba(124,58,237,0.3); border-radius: 10px; padding: 16px; margin-bottom: 12px; display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 12px; }
    .reconf-name { font-weight: 700; color: white; }
    .reconf-email { font-size: 0.85rem; color: #94a3b8; }
    .reconf-id { font-size: 0.75rem; color: #475569; margin-top: 2px; }
    .reconf-actions { display: flex; gap: 8px; }

    /* ---- Modals ---- */
    .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 50; display: none; align-items: center; justify-content: center; padding: 24px; }
    .modal-box { background: #1e293b; border: 1px solid #334155; border-radius: 12px; padding: 28px; width: 100%; max-width: 480px; }
    .modal-box h3 { font-size: 1.1rem; font-weight: 700; color: white; margin-bottom: 20px; }
    .modal-field { margin-bottom: 14px; }
    .modal-field label { display: block; font-size: 0.85rem; color: #94a3b8; margin-bottom: 6px; }
    .modal-field input,
    .modal-field textarea {
      width: 100%; padding: 10px 14px;
      background: #0f172a; border: 1px solid #334155;
      border-radius: 8px; color: white;
      font-family: var(--font); font-size: 0.9rem; outline: none;
    }
    .modal-field textarea { resize: vertical; }
    .modal-field input:focus,
    .modal-field textarea:focus { border-color: #3b82f6; }
    .modal-actions { display: flex; gap: 10px; justify-content: flex-end; margin-top: 6px; }
    .btn-cancel { padding: 9px 18px; background: transparent; border: 1px solid #334155; color: #94a3b8; border-radius: 8px; cursor: pointer; font-family: var(--font); }
    .btn-cancel:hover { background: #334155; }
    .btn-confirm-red { padding: 9px 18px; background: #dc2626; color: white; border: none; border-radius: 8px; cursor: pointer; font-family: var(--font); font-weight: 600; }
    .btn-confirm-red:hover { background: #b91c1c; }

    .modal-details { max-height: 65vh; overflow-y: auto; }
    .detail-row { display: flex; justify-content: space-between; border-bottom: 1px solid #334155; padding: 10px 0; font-size: 0.85rem; }
    .detail-key { color: #64748b; font-weight: 600; text-transform: uppercase; font-size: 0.75rem; }
    .detail-val { color: #e2e8f0; text-align: right; max-width: 60%; word-break: break-word; }

    .empty-state { text-align: center; padding: 40px; color: #475569; }

    .section-hidden { display: none; }
  </style>
</head>
<body>

  <!-- Top bar -->
  <header class="topbar">
    <div class="topbar-inner">
      <div class="topbar-left">
        <a href="/" class="topbar-back">&#8592;</a>
        <div>
          <p class="topbar-title">Painel da Secretaria</p>
          <p class="topbar-subtitle">Gestao de Matriculas</p>
        </div>
      </div>
      <div class="topbar-right">
        <span class="topbar-user">Ola, <strong><%= usuario %></strong></span>
        <button class="btn-icon btn-yellow" onclick="document.getElementById('modalSenha').style.display='flex'">Senha</button>
        <a href="/logout/secretaria" onclick="return confirm('Tem a certeza?')">
          <button class="btn-icon btn-red">Sair</button>
        </a>
      </div>
    </div>
  </header>

  <!-- Modal senha -->
  <div id="modalSenha" class="modal-overlay">
    <div class="modal-box">
      <h3>Alterar Senha</h3>
      <form method="POST" action="/secretaria/alterar-senha">
        <div class="modal-field">
          <label>Senha actual</label>
          <input type="password" name="senha_atual" required placeholder="Senha actual">
        </div>
        <div class="modal-field">
          <label>Nova senha</label>
          <input type="password" name="senha_nova" required placeholder="Nova senha">
        </div>
        <div class="modal-actions">
          <button type="button" class="btn-cancel" onclick="document.getElementById('modalSenha').style.display='none'">Cancelar</button>
          <button type="submit" class="btn-icon btn-yellow">Actualizar</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal recusar matricula -->
  <div id="modalRecusar" class="modal-overlay">
    <div class="modal-box">
      <h3>Recusar Matricula</h3>
      <form id="formRecusar" method="POST">
        <div class="modal-field">
          <label>Aluno</label>
          <input id="recusarNome" type="text" readonly>
        </div>
        <div class="modal-field">
          <label>Motivo *</label>
          <textarea name="mensagem" rows="4" required placeholder="Descreva o motivo da recusa"></textarea>
        </div>
        <div class="modal-actions">
          <button type="button" class="btn-cancel" onclick="document.getElementById('modalRecusar').style.display='none'">Cancelar</button>
          <button type="submit" class="btn-confirm-red">Recusar</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal detalhes -->
  <div id="modalDetalhes" class="modal-overlay">
    <div class="modal-box" style="max-width:600px">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">
        <h3 style="margin:0">Detalhes do Aluno</h3>
        <button onclick="document.getElementById('modalDetalhes').style.display='none'" style="background:none;border:none;color:#94a3b8;font-size:1.2rem;cursor:pointer">&#10005;</button>
      </div>
      <div id="detalhesConteudo" class="modal-details"></div>
    </div>
  </div>

  <main class="main">

    <% if (flash) { %>
    <div class="flash <%= flash.tipo === 'sucesso' ? 'flash-ok' : 'flash-err' %>"><%= flash.msg %></div>
    <% } %>

    <!-- Stats -->
    <div class="stats-grid">
      <div class="stat-card stat-blue">  <p class="stat-label">Total</p>      <p class="stat-num"><%= stats.total %></p></div>
      <div class="stat-card stat-yellow"><p class="stat-label">Pendentes</p>  <p class="stat-num"><%= stats.pendentes %></p></div>
      <div class="stat-card stat-green"> <p class="stat-label">Aprovados</p>  <p class="stat-num"><%= stats.aprovados %></p></div>
      <div class="stat-card stat-red">   <p class="stat-label">Recusados</p>  <p class="stat-num"><%= stats.recusados %></p></div>
      <div class="stat-card stat-purple"><p class="stat-label">Reconf.</p>    <p class="stat-num"><%= stats.reconfirmacoes %></p></div>
    </div>

    <!-- Nav -->
    <div class="nav-tabs">
      <button class="tab-btn tab-blue"   onclick="showSection('dashboard')">Dashboard</button>
      <button class="tab-btn tab-blue"   onclick="showSection('alunos')">Matriculas</button>
      <button class="tab-btn tab-purple" onclick="showSection('reconfirmacoes')">Reconfirmacoes</button>
    </div>

    <!-- Dashboard -->
    <div id="sec-dashboard" class="section-card">
      <h2>Resumo Geral</h2>
      <div class="summary-grid">
        <div class="summary-box">
          <p>Taxa de Aprovacao</p>
          <p class="summary-big text-blue"><%= stats.total > 0 ? Math.round((stats.aprovados / stats.total) * 100) : 0 %>%</p>
        </div>
        <div class="summary-box">
          <p>Total de Alunos</p>
          <p class="summary-big text-green"><%= stats.total %></p>
        </div>
      </div>
    </div>

    <!-- Matriculas -->
    <div id="sec-alunos" class="section-card section-hidden">
      <h2>Lista de Alunos</h2>
      <div class="search-row">
        <form method="GET" action="/secretaria/painel" style="display:flex;gap:8px;flex:1">
          <input type="text" name="buscar" placeholder="Pesquisar por nome..." value="<%= busca %>">
          <button type="submit" class="btn-search">Pesquisar</button>
        </form>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Nome</th>
              <th>Email</th>
              <th>Curso</th>
              <th>Estado</th>
              <th>Accoes</th>
            </tr>
          </thead>
          <tbody>
            <% alunos.forEach(a => { %>
            <tr>
              <td><%= a.nome %></td>
              <td class="email"><%= a.email %></td>
              <td><%= a.curso %></td>
              <td>
                <% if (a.estado === 'Pendente') { %>
                  <span class="badge-row badge-pend">Pendente</span>
                <% } else if (a.estado === 'Aprovado') { %>
                  <span class="badge-row badge-aprov">Aprovado</span>
                <% } else { %>
                  <span class="badge-row badge-recus">Recusado</span>
                <% } %>
              </td>
              <td>
                <div class="action-btns">
                  <% if (a.estado === 'Pendente') { %>
                  <form method="POST" action="/secretaria/aprovar/<%= a.id %>" style="margin:0">
                    <button type="submit" class="btn-approve" onclick="return confirm('Aprovar matricula de <%= a.nome.replace(/'/g, `\\'`) %>?')">Aprovar</button>
                  </form>
                  <button class="btn-reject-sm" onclick="openRecusar(<%= a.id %>, '<%= a.nome.replace(/'/g, `\\'`) %>')">Recusar</button>
                  <% } %>
                  <button class="btn-view" onclick='openDetalhes(<%- JSON.stringify(a) %>)'>Ver</button>
                </div>
              </td>
            </tr>
            <% }) %>
            <% if (alunos.length === 0) { %>
            <tr><td colspan="5" class="empty-state">Nenhum aluno encontrado</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Reconfirmacoes -->
    <div id="sec-reconfirmacoes" class="section-card section-hidden">
      <h2>Reconfirmacoes Pendentes</h2>
      <% reconfirmacoes.forEach(r => { %>
      <div class="reconf-item">
        <div>
          <p class="reconf-name"><%= r.nome %></p>
          <p class="reconf-email"><%= r.email %></p>
          <p class="reconf-id">ID: <%= r.id_oficial %></p>
        </div>
        <div class="reconf-actions">
          <form method="POST" action="/secretaria/aceitar-reconf/<%= r.id %>" style="margin:0">
            <button type="submit" class="btn-approve">Aceitar</button>
          </form>
          <form method="POST" action="/secretaria/recusar-reconf/<%= r.id %>" style="margin:0">
            <button type="submit" class="btn-reject-sm">Recusar</button>
          </form>
        </div>
      </div>
      <% }) %>
      <% if (reconfirmacoes.length === 0) { %>
      <p class="empty-state">Nenhuma reconfirmacao pendente</p>
      <% } %>
    </div>

  </main>

  <script>
    const labelMap = {
      nome:'Nome', email:'Email', curso:'Curso', classe:'Classe',
      periodo:'Periodo', estado:'Estado', id_oficial:'ID Oficial',
      nif:'NIF', telefone:'Telefone', sexo:'Sexo',
      escola_anterior:'Escola Anterior', endereco:'Endereco',
      data_cadastro:'Cadastro', mensagem_recusa:'Motivo Recusa'
    };

    function showSection(id) {
      ['dashboard','alunos','reconfirmacoes'].forEach(s => {
        document.getElementById('sec-' + s).classList.add('section-hidden');
      });
      document.getElementById('sec-' + id).classList.remove('section-hidden');
    }

    function openRecusar(id, nome) {
      document.getElementById('formRecusar').action = '/secretaria/recusar/' + id;
      document.getElementById('recusarNome').value = nome;
      document.getElementById('modalRecusar').style.display = 'flex';
    }

    function openDetalhes(obj) {
      const c = document.getElementById('detalhesConteudo');
      c.innerHTML = '';
      Object.entries(labelMap).forEach(([key, label]) => {
        const val = obj[key] ?? '—';
        c.innerHTML += `<div class="detail-row"><span class="detail-key">${label}</span><span class="detail-val">${val}</span></div>`;
      });
      document.getElementById('modalDetalhes').style.display = 'flex';
    }

    ['modalSenha','modalRecusar','modalDetalhes'].forEach(id => {
      document.getElementById(id).addEventListener('click', function(e) {
        if (e.target === this) this.style.display = 'none';
      });
    });

    showSection('<%= secao %>');
  </script>
</body>
</html>
