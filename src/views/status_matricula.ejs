<!DOCTYPE html>
<html lang="pt">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Status da Matrícula | EduMatric</title>
<script src="https://cdn.tailwindcss.com"></script>
<style>
body { background: linear-gradient(-45deg,#002366,#0047ab,#001a40,#0066ff); background-size:400% 400%; animation:gradientMove 15s ease infinite; }
@keyframes gradientMove { 0%{background-position:0% 50%} 50%{background-position:100% 50%} 100%{background-position:0% 50%} }
.glass { background:rgba(255,255,255,0.15); backdrop-filter:blur(18px); border:1px solid rgba(255,255,255,0.2); }
</style>
</head>
<body class="text-white flex items-center justify-center min-h-screen p-6">
<a href="/" class="absolute top-6 left-6 text-2xl hover:opacity-80 transition">←</a>

<div class="glass p-8 rounded-2xl w-full max-w-2xl my-12">
<h2 class="text-3xl font-bold mb-2 text-center">Status de Matrícula</h2>
<p class="text-center text-blue-100 text-sm mb-6">Verifique o andamento da sua inscrição</p>

<form method="POST" action="/status-matricula" class="space-y-4 mb-8">
    <div>
        <label class="text-sm mb-2 block font-semibold">Nome Completo</label>
        <input type="text" name="nome" placeholder="Digite o seu nome completo" required class="p-3 rounded text-black w-full focus:outline-none">
    </div>
    <div>
        <label class="text-sm mb-2 block font-semibold">Email</label>
        <input type="email" name="email" placeholder="Digite o seu email" required class="p-3 rounded text-black w-full focus:outline-none">
    </div>
    <button type="submit" class="w-full bg-white text-blue-900 p-3 rounded font-bold hover:bg-gray-100 transition">Verificar Status</button>
</form>

<% if (erro) { %>
<div class="p-4 bg-red-500/30 border border-red-400 rounded text-red-100 text-sm"><%= erro %></div>
<% } %>

<% if (aluno) { %>
<div class="space-y-6">
    <div class="bg-white/10 border border-white/20 rounded-lg p-6">
        <div class="flex items-center justify-between flex-wrap gap-4">
            <div>
                <h3 class="text-2xl font-bold"><%= aluno.nome %></h3>
                <% if (aluno.id_oficial) { %>
                <p class="text-blue-200 text-sm">ID Oficial: <strong><%= aluno.id_oficial %></strong></p>
                <% } %>
            </div>
            <div>
                <% if (aluno.estado === 'Pendente') { %>
                    <span class="inline-block bg-yellow-500/30 text-yellow-100 px-4 py-2 rounded-lg font-bold">Em análise</span>
                <% } else if (aluno.estado === 'Aprovado') { %>
                    <span class="inline-block bg-green-500/30 text-green-100 px-4 py-2 rounded-lg font-bold">Aprovado</span>
                <% } else { %>
                    <span class="inline-block bg-red-500/30 text-red-100 px-4 py-2 rounded-lg font-bold">Recusado</span>
                <% } %>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="bg-white/5 border border-white/10 rounded-lg p-4">
            <p class="text-blue-200 text-xs font-semibold mb-1">CURSO</p>
            <p class="text-xl font-bold"><%= aluno.curso %></p>
        </div>
        <div class="bg-white/5 border border-white/10 rounded-lg p-4">
            <p class="text-blue-200 text-xs font-semibold mb-1">CLASSE</p>
            <p class="text-xl font-bold"><%= aluno.classe %></p>
        </div>
        <div class="bg-white/5 border border-white/10 rounded-lg p-4">
            <p class="text-blue-200 text-xs font-semibold mb-1">PERÍODO</p>
            <p class="text-xl font-bold"><%= aluno.periodo %></p>
        </div>
        <div class="bg-white/5 border border-white/10 rounded-lg p-4">
            <p class="text-blue-200 text-xs font-semibold mb-1">TELEFONE</p>
            <p class="text-xl font-bold"><%= aluno.telefone || '—' %></p>
        </div>
    </div>

    <div class="bg-white/5 border border-white/10 rounded-lg p-6">
        <h4 class="font-bold text-lg mb-4">Informações Pessoais</h4>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
            <div><p class="text-blue-200 text-xs font-semibold mb-1">EMAIL</p><p><%= aluno.email %></p></div>
            <div><p class="text-blue-200 text-xs font-semibold mb-1">NIF</p><p><%= aluno.nif || '—' %></p></div>
            <div><p class="text-blue-200 text-xs font-semibold mb-1">SEXO</p><p><%= aluno.sexo || '—' %></p></div>
            <div><p class="text-blue-200 text-xs font-semibold mb-1">ENDEREÇO</p><p><%= aluno.endereco || '—' %></p></div>
        </div>
    </div>

    <div class="bg-white/5 border border-white/10 rounded-lg p-4">
        <p class="text-blue-200 text-xs font-semibold mb-1">DATA DE CADASTRO</p>
        <p class="text-lg font-bold"><%= new Date(aluno.data_cadastro).toLocaleDateString('pt-BR') %></p>
    </div>

    <% if (aluno.estado === 'Recusado' && aluno.mensagem_recusa) { %>
    <div class="bg-red-500/20 border border-red-400/50 rounded-lg p-6">
        <h4 class="font-bold text-lg mb-2 text-red-100">Motivo da Recusa</h4>
        <p class="text-red-100"><%= aluno.mensagem_recusa %></p>
    </div>
    <% } %>

    <% if (aluno.estado === 'Aprovado') { %>
    <div class="bg-blue-500/20 border border-blue-400/50 rounded-lg p-6">
        <p class="text-green-100 font-semibold mb-3">Parabéns! A sua matrícula foi aprovada.</p>
        <ul class="space-y-2 text-sm text-blue-100">
            <li>→ Efectue o pagamento das taxas de inscrição (15.000 Kz)</li>
            <li>→ Faça upload do comprovante de pagamento</li>
            <li>→ Dirija-se à secretaria para confirmação final</li>
        </ul>
    </div>
    <% } %>

    <% if (aluno.estado === 'Pendente') { %>
    <div class="bg-blue-500/20 border border-blue-400/50 rounded-lg p-6">
        <p class="text-blue-100">A sua matrícula está a ser analisada pela secretaria. Volte em breve para ver actualizações.</p>
    </div>
    <% } %>

    <div class="flex gap-3">
        <a href="/" class="flex-1 bg-gray-600 hover:bg-gray-700 text-white p-3 rounded font-bold transition text-center">Voltar</a>
    </div>
</div>
<% } %>
</div>
</body>
</html>
