<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Status da Matricula | EduMatric</title>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <style>
    body { background: linear-gradient(-45deg,#002366,#0047ab,#001a40,#0066ff); background-size:400% 400%; animation:gradientMove 15s ease infinite; }
    @keyframes gradientMove { 0%{background-position:0% 50%} 50%{background-position:100% 50%} 100%{background-position:0% 50%} }

    .page-center { align-items: flex-start; padding-top: 64px; }

    .status-card {
      width: 100%; max-width: 680px; margin: 0 auto;
      padding: 40px; border-radius: 20px;
      background: rgba(255,255,255,0.15);
      backdrop-filter: blur(18px);
      border: 1px solid rgba(255,255,255,0.2);
    }
    .status-card h2 { font-size: 1.9rem; font-weight: 700; text-align: center; margin-bottom: 6px; }
    .status-card .subtitle { text-align: center; color: rgba(191,219,254,0.7); font-size: 0.9rem; margin-bottom: 28px; }

    .search-form { margin-bottom: 32px; }
    .search-form .form-group { margin-bottom: 14px; }
    .search-form label { display: block; font-size: 0.85rem; font-weight: 600; margin-bottom: 6px; }
    .search-form input { width: 100%; padding: 11px 14px; background: white; color: #111; border: none; border-radius: 6px; font-size: 0.95rem; font-family: var(--font); outline: none; }
    .btn-search { width: 100%; padding: 13px; background: white; color: #001a40; font-weight: 700; font-size: 1rem; border: none; border-radius: 8px; cursor: pointer; transition: background 0.2s; font-family: var(--font); }
    .btn-search:hover { background: #e0e7ff; }

    /* Result sections */
    .result-header { background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); border-radius: 10px; padding: 24px; display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 16px; margin-bottom: 16px; }
    .result-name { font-size: 1.5rem; font-weight: 700; }
    .result-id { font-size: 0.85rem; color: rgba(191,219,254,0.7); margin-top: 4px; }
    .result-id span { color: white; font-weight: 600; }

    .badge-status { display: inline-block; padding: 8px 18px; border-radius: 8px; font-weight: 700; font-size: 0.9rem; }
    .badge-pendente  { background: rgba(234,179,8,0.25);  color: #fef08a; }
    .badge-aprovado  { background: rgba(34,197,94,0.25);  color: #86efac; }
    .badge-recusado  { background: rgba(239,68,68,0.25);  color: #fca5a5; }

    .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 16px; }
    @media (max-width: 500px) { .info-grid { grid-template-columns: 1fr; } }
    .info-box-item { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 14px; }
    .info-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(147,197,253,0.8); margin-bottom: 4px; }
    .info-value { font-size: 1.1rem; font-weight: 700; }

    .info-section { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 20px; margin-bottom: 16px; }
    .info-section h4 { font-size: 1rem; font-weight: 700; margin-bottom: 16px; }
    .info-section-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; font-size: 0.9rem; }
    .info-section-grid .sub-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(147,197,253,0.8); margin-bottom: 2px; }

    .result-note { border-radius: 10px; padding: 20px; margin-bottom: 16px; font-size: 0.9rem; line-height: 1.6; }
    .note-reject { background: rgba(239,68,68,0.15);  border: 1px solid rgba(239,68,68,0.3);  }
    .note-reject h4  { color: #fca5a5; margin-bottom: 8px; font-weight: 700; }
    .note-reject p   { color: #fca5a5; }
    .note-approve { background: rgba(59,130,246,0.15); border: 1px solid rgba(59,130,246,0.3); }
    .note-approve p  { color: #93c5fd; }
    .note-approve ul { margin-top: 10px; padding-left: 0; list-style: none; }
    .note-approve li { color: #93c5fd; margin-bottom: 6px; }
    .note-pending { background: rgba(59,130,246,0.1); border: 1px solid rgba(59,130,246,0.2); }
    .note-pending p  { color: #93c5fd; }

    .result-actions { display: flex; gap: 12px; }
    .btn-back { flex: 1; padding: 12px; background: rgba(107,114,128,0.5); color: white; font-weight: 700; border: none; border-radius: 8px; cursor: pointer; font-family: var(--font); font-size: 0.95rem; text-align: center; }
    .btn-back:hover { background: rgba(107,114,128,0.7); }
  </style>
</head>
<body class="bg-blue-gradient">
  <a href="/" class="back-link">&#8592;</a>

  <div class="page-center">
    <div class="status-card">
      <h2>Status de Matricula</h2>
      <p class="subtitle">Verifique o andamento da sua inscricao</p>

      <div class="search-form">
        <form method="POST" action="/status-matricula">
          <div class="form-group">
            <label>Nome Completo</label>
            <input type="text" name="nome" placeholder="Digite o seu nome completo" required>
          </div>
          <div class="form-group">
            <label>Email</label>
            <input type="email" name="email" placeholder="Email usado na candidatura" required>
          </div>
          <button type="submit" class="btn-search">Verificar Status</button>
        </form>
      </div>

      <% if (erro) { %><div class="alert alert-error"><%= erro %></div><% } %>

      <% if (aluno) { %>

        <div class="result-header">
          <div>
            <p class="result-name"><%= aluno.nome %></p>
            <% if (aluno.id_oficial) { %>
            <p class="result-id">ID Oficial: <span><%= aluno.id_oficial %></span></p>
            <% } %>
          </div>
          <% if (aluno.estado === 'Pendente') { %>
            <span class="badge-status badge-pendente">Em analise</span>
          <% } else if (aluno.estado === 'Aprovado') { %>
            <span class="badge-status badge-aprovado">Aprovado</span>
          <% } else { %>
            <span class="badge-status badge-recusado">Recusado</span>
          <% } %>
        </div>

        <div class="info-grid">
          <div class="info-box-item"><p class="info-label">Curso</p><p class="info-value"><%= aluno.curso %></p></div>
          <div class="info-box-item"><p class="info-label">Classe</p><p class="info-value"><%= aluno.classe %></p></div>
          <div class="info-box-item"><p class="info-label">Periodo</p><p class="info-value"><%= aluno.periodo %></p></div>
          <div class="info-box-item"><p class="info-label">Telefone</p><p class="info-value"><%= aluno.telefone || '—' %></p></div>
        </div>

        <div class="info-section">
          <h4>Informacoes Pessoais</h4>
          <div class="info-section-grid">
            <div><p class="sub-label">Email</p><p><%= aluno.email %></p></div>
            <div><p class="sub-label">NIF</p><p><%= aluno.nif || '—' %></p></div>
            <div><p class="sub-label">Sexo</p><p><%= aluno.sexo || '—' %></p></div>
            <div><p class="sub-label">Data de Cadastro</p><p><%= new Date(aluno.data_cadastro).toLocaleDateString('pt-BR') %></p></div>
          </div>
        </div>

        <% if (aluno.estado === 'Recusado' && aluno.mensagem_recusa) { %>
        <div class="result-note note-reject">
          <h4>Motivo da Recusa</h4>
          <p><%= aluno.mensagem_recusa %></p>
        </div>
        <% } %>

        <% if (aluno.estado === 'Aprovado') { %>
        <div class="result-note note-approve">
          <p><strong>Matricula Aprovada!</strong> Siga os proximos passos:</p>
          <ul>
            <li>→ Efectue o pagamento das taxas de inscricao (15.000 Kz)</li>
            <li>→ Faca upload do comprovante de pagamento</li>
            <li>→ Dirija-se a secretaria para confirmacao final</li>
          </ul>
        </div>
        <% } %>

        <% if (aluno.estado === 'Pendente') { %>
        <div class="result-note note-pending">
          <p>A sua matricula esta a ser analisada pela secretaria. Volte em breve para actualizacoes.</p>
        </div>
        <% } %>

        <div class="result-actions">
          <a href="/" class="btn-back">Voltar ao inicio</a>
        </div>

      <% } %>
    </div>
  </div>
</body>
</html>
